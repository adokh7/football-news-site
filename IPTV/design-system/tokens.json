{
  "$schema": "design-tokens",
  "meta": { "brand": "IPTV Premium Sverige", "theme": "Bold Luxury Dark", "version": "1.0.0" },
  "color": {
    "brand": {
      "primary": { "50": "#FFF9EB", "100": "#FDEEC8", "200": "#FADD91", "300": "#F6C75A", "400": "#F2B233", "500": "#E6A417", "600": "#C4880D", "700": "#9C6A0E", "800": "#7E5512", "900": "#684614" },
      "secondary": { "50": "#EEF4FF", "100": "#D9E5FF", "200": "#BCD0FF", "300": "#8EB0FF", "400": "#5985FF", "500": "#335EFF", "600": "#1B3DF5", "700": "#142CD1", "800": "#1626A8", "900": "#182784" }
    },
    "neutral": {
      "0": "#FFFFFF", "50": "#F7F7F8", "100": "#ECECEF", "200": "#D5D5DC", "300": "#B1B1BC", "400": "#8A8A98", "500": "#6C6C7A", "600": "#565663", "700": "#464650",
      "800": "#2A2A32", "850": "#1E1E24", "900": "#141419", "950": "#0B0B0F", "1000": "#050507"
    },
    "semantic": {
      "success": { "base": "#22C55E", "subtle": "#0E2B1A", "text": "#4ADE80" },
      "warning": { "base": "#F59E0B", "subtle": "#2D2107", "text": "#FBBF24" },
      "error":   { "base": "#EF4444", "subtle": "#2F1212", "text": "#F87171" },
      "info":    { "base": "#3B82F6", "subtle": "#0F1D33", "text": "#60A5FA" },
      "live":    { "base": "#FF2D55", "subtle": "#33101A", "text": "#FF5C7A" }
    },
    "dark": {
      "bg":          "#0B0B0F",
      "bg-elevated": "#141419",
      "bg-card":     "#1E1E24",
      "bg-hover":    "#2A2A32",
      "border":      "#2A2A32",
      "border-strong":"#464650",
      "text-primary":  "#F7F7F8",
      "text-secondary":"#B1B1BC",
      "text-tertiary": "#8A8A98",
      "text-inverse":  "#0B0B0F",
      "accent":        "#F2B233",
      "accent-hover":  "#F6C75A",
      "accent-pressed":"#E6A417",
      "focus-ring":    "#5985FF"
    },
    "gradient": {
      "hero":  "linear-gradient(135deg, #0B0B0F 0%, #141419 50%, #1B1506 100%)",
      "gold":  "linear-gradient(120deg, #F6C75A 0%, #E6A417 55%, #C4880D 100%)",
      "card":  "linear-gradient(180deg, rgba(242,178,51,0.08) 0%, rgba(11,11,15,0) 60%)",
      "scrim": "linear-gradient(180deg, rgba(11,11,15,0) 0%, rgba(11,11,15,0.92) 100%)"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "'Clash Display', 'Inter', system-ui, sans-serif",
      "body": "'Inter', system-ui, -apple-system, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, monospace"
    },
    "scale": {
      "display-xl": { "size": "72px", "lineHeight": "1.05", "weight": 600, "tracking": "-0.02em", "mobile": "44px" },
      "display":    { "size": "56px", "lineHeight": "1.08", "weight": 600, "tracking": "-0.02em", "mobile": "36px" },
      "h1":         { "size": "40px", "lineHeight": "1.15", "weight": 600, "tracking": "-0.015em", "mobile": "32px" },
      "h2":         { "size": "32px", "lineHeight": "1.2",  "weight": 600, "tracking": "-0.01em",  "mobile": "26px" },
      "h3":         { "size": "24px", "lineHeight": "1.3",  "weight": 600, "tracking": "-0.005em", "mobile": "20px" },
      "h4":         { "size": "20px", "lineHeight": "1.4",  "weight": 500, "tracking": "0",        "mobile": "18px" },
      "body-lg":    { "size": "18px", "lineHeight": "1.6",  "weight": 400, "tracking": "0" },
      "body":       { "size": "16px", "lineHeight": "1.6",  "weight": 400, "tracking": "0" },
      "caption":    { "size": "13px", "lineHeight": "1.45", "weight": 500, "tracking": "0.02em" }
    }
  },
  "spacing": {
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px",
    "6": "32px", "7": "40px", "8": "48px", "9": "64px", "10": "80px", "11": "96px", "12": "128px"
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "16px", "xl": "24px", "full": "9999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.4)",
    "md": "0 4px 12px rgba(0,0,0,0.45)",
    "lg": "0 12px 32px rgba(0,0,0,0.55)",
    "glow-gold": "0 0 24px rgba(242,178,51,0.35)",
    "glow-live": "0 0 16px rgba(255,45,85,0.45)"
  },
  "breakpoints": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px", "tv": "1920px" },
  "motion": {
    "duration": { "instant": "100ms", "fast": "160ms", "base": "240ms", "slow": "400ms", "cinematic": "700ms" },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "enter": "cubic-bezier(0, 0, 0.2, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "zIndex": { "base": 0, "dropdown": 100, "sticky": 200, "overlay": 300, "modal": 400, "toast": 500 }
}
